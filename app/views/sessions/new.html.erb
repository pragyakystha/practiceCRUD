<% if flash[:notice] %>
  <div style="color: green;">
    <%= flash[:notice] %>
  </div>
<% end %>

<% if flash[:alert] %>
  <div style="color: red;">
    <%= flash[:alert] %>
  </div>
<% end %>

<%= form_with(url: login_path, method: :post, data: { turbo: false})  do |form| %>
  <div>
    <%= form.label :email %>
    <%= form.text_field :email %>
  </div>
  <div>
    <%= form.label :password %>
    <%= form.password_field :password %>
  </div>
  <%= form.submit "Login" %>
<% end %>
<%= link_to "Don't have an account? Register", register_path %>
