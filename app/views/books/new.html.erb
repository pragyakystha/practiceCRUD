<%= form_with(model: @book, local: true) do |f| %>
  <div>
    <%= f.label :name, "Full Name", style: "color: blue; font-weight: bold;" %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :publication_date, "Publication Date", style: "color: blue; font-weight: bold;" %>
    <%= f.date_field :publication_date %>
  </div>
  
  <div>
    <%= f.label :price, "Price", style: "color: blue; font-weight: bold;" %>
    <%= f.number_field :price %>
  </div>

  <div>
    <%= f.label :author_id, "Author" , style: "color: blue; font-weight: bold;" %>
    <% if @authors.any? %>
    <%= f.collection_select :author_id, @authors, :id, :name, prompt: "Select an author"%>
     <% else %>
      <p>No authors available. Please add an author first.</p>
    <% end %>
    
  </div>
  
  <%= f.submit "Create Book" %>
<% end %>



