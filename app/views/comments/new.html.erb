<h1><%= @post.title %></h1>
<p><%= @post.body %></p>

<h3>Comments:</h3>
<ul id="comments-list">
  <%= render @post.comments %>
</ul>

<%= form_with(model: [@post, @post.comments.build], remote: true) do |form| %>
  <%= form.text_area :body, placeholder: "Add a comment..." %>
  <%= form.submit "Submit" %>
<% end %>

